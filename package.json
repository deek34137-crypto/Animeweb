{
  "name": "aniworld",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "cursors:build": "node scripts/generate-cursor-manifest.js",
    "build": "npm run cursors:build && prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "prisma generate",
    "sync-user-stats": "npx tsx scripts/sync-user-stats.ts",
    "analyze": "ANALYZE=true npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.100.14",
    "@types/node-cron": "^3.0.11",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.40.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.5.0",
    "node-fetch": "^3.3.2",
    "opossum": "^10.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "^3.6.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
