datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String      @id @default(cuid())
  username      String      @unique
  email         String      @unique
  password      String?     // Hashed password for credentials auth
  displayName   String?
  avatar        String?
  banner        String?
  bio           String?
  role          String      @default("USER")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Tracker Sync details
  malAccessToken      String?
  malRefreshToken     String?
  malExpiresAt        DateTime?
  malUsername         String?
  
  anilistAccessToken  String?
  anilistExpiresAt    DateTime?
  anilistUsername     String?
  
  syncToMal           Boolean     @default(true)
  syncToAnilist       Boolean     @default(true)

  
  // Auth relations (optional / future-proofing for database sessions)
  accounts      Account[]
  sessions      Session[]
  
  // Tracking & List relations
  listEntries   ListEntry[]
  watchProgress WatchProgress[]
  watchHistory  WatchHistory[]
  bookmarks     EpisodeBookmark[]
  preferences   UserPreferences?
  collections   Collection[]
  activityLogs  ActivityLog[]
  colMembers    CollectionMember[]
  insightsCache Json?
  insightsDirty Boolean      @default(true)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ListEntry {
  id              String         @id @default(cuid())
  userId          String
  animeId         String         // Jikan / MAL ID stored as string
  animeTitle      String         // Cache the title for Continue Watching
  animeImage      String         // Cache the image for Continue Watching
  animeEpisodes   Int?           // Cache total episodes count
  status          String         // watching, completed, dropped, paused, planning, rewatching
  score           Float?         // 1-10 with 0.5 steps
  episodesWatched Int            @default(0)
  rewatchCount    Int            @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  notes           String?
  isPrivate       Boolean        @default(false)
  isFavorite      Boolean        @default(false)
  isTopFavorite   Boolean        @default(false)
  topFavoriteOrder Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchSessions   WatchSession[]

  @@unique([userId, animeId])
  @@index([userId, status])
}

model WatchSession {
  id           String    @id @default(cuid())
  listEntryId  String
  watchTime    Int       @default(0) // in minutes
  watchedAt    DateTime  @default(now())
  
  listEntry    ListEntry @relation(fields: [listEntryId], references: [id], onDelete: Cascade)
}

model WatchProgress {
  id            String   @id @default(cuid())
  userId        String
  animeId       String
  episode       Int
  position      Int      // playback position in seconds
  duration      Int      // total video duration in seconds
  lastWatchedAt DateTime @default(now()) @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId, episode])
  @@index([userId])
}

model WatchHistory {
  id          String   @id @default(cuid())
  userId      String
  animeId     String
  animeTitle  String
  animeImage  String
  episode     Int
  position    Int      @default(0) // playback position in seconds when last seen
  duration    Int      @default(0) // total duration in seconds
  completedAt DateTime @default(now()) @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId, episode])
  @@index([userId])
}

model StreamingProvider {
  id          String   @id @default(cuid())
  animeId     String
  provider    String   // e.g., 'gogoanime'
  providerId  String   // e.g., slug/id
  updatedAt   DateTime @updatedAt

  @@index([animeId])
}

model AnimeEpisodeCache {
  id         String   @id @default(cuid())
  animeId    String   @unique
  episodes   Json     // EpisodeData[] serialized
  totalCount Int
  cachedAt   DateTime @default(now())
  expiresAt  DateTime
}

model EpisodeBookmark {
  id        String   @id @default(cuid())
  userId    String
  animeId   String
  episode   Int
  timestamp Int
  note      String?  // rich text / markdown
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, animeId])
  @@index([userId, animeId, episode])
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  autoplayNext      Boolean  @default(true)
  autoSkipIntro     Boolean  @default(false)
  autoSkipOutro     Boolean  @default(false)
  autoplayCountdown Int      @default(5)
  preferredLanguage String   @default("sub")
  preferredQuality  String   @default("Auto")
  preferredSpeed    Float    @default(1.0)
  defaultVolume     Float    @default(1.0)
  showResumePrompt  Boolean  @default(true)
  reducedMotion     Boolean  @default(false)
  activeCursor      String?
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CollectionVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum CoverSelectionType {
  AUTO
  CUSTOM
  ANIME
}

enum ActivityAction {
  ADD_LIBRARY
  STATUS_CHANGE
  RATED
  FAVORITE
  CREATE_COLLECTION
  UPDATE_COLLECTION
  SOFT_DELETE_COLLECTION
  RESTORE_COLLECTION
  DELETE_COLLECTION
  ADD_COLLECTION_ENTRY
  REMOVE_COLLECTION_ENTRY
  RESTORE
  DELETE
}

model Collection {
  id                 String               @id @default(cuid())
  userId             String
  name               String
  slug               String               @unique
  description        String?
  coverSelectionType CoverSelectionType   @default(AUTO)
  coverImage         String?
  coverAnimeId       String?
  visibility         CollectionVisibility @default(PRIVATE)
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries            CollectionEntry[]
  members            CollectionMember[]

  @@unique([userId, name])
  @@index([userId])
}

model CollectionEntry {
  id           String     @id @default(cuid())
  collectionId String
  animeId      String
  animeSnapshot Json?
  sortOrder    Int        @default(0)
  notes        String?
  score        Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, animeId])
  @@index([collectionId])
}

model ActivityLog {
  id         String         @id @default(cuid())
  userId     String
  action     ActivityAction
  animeId    String?
  animeTitle String?
  details    String?
  createdAt  DateTime       @default(now())
  
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CollectionMember {
  id           String     @id @default(cuid())
  collectionId String
  userId       String
  role         String     @default("VIEWER") // OWNER, MODERATOR, EDITOR, VIEWER
  createdAt    DateTime   @default(now())
  
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId])
  @@index([collectionId])
  @@index([userId])
}

